{% extends 'partials/base-nonav.html.twig' %}

{% block body %}
    <body id="page">
{% endblock %}

{% block content %}

<script>
$(document).ready(function() {

    {% set projectid = page.uri.query.projectid|int %}
    {% set sceneid = projects[projectid].scenes|length + 1 %}

    const params = jQuery.param({ 
        'projectid': '{{ projectid }}', 
        'sceneid': '{{ sceneid }}'
    });
    console.log("/scenarist?" + params);
    window.location.href = "/scenarist?" + params;
});
</script>
{% endblock %}