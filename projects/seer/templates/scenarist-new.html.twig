{% extends 'partials/base-nonav.html.twig' %}

{% block body %}
    <body id="page">
{% endblock %}

{% block content %}
<script>
$(document).ready(function() {

    {% set projectid = page.uri.query.projectid  %}

    const params = jQuery.param({ 
        'projectid': '{{ projectid }}', 
        'sceneid': '{{ projects[projectid].scenes|length }}'
    });
    window.location.href = "/scenarist?" + params;
});
</script>
{% endblock %}