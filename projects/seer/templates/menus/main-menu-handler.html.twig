
<script>

    function selectMode( mode ) {
        
        // console.log($("#menu-mode").text());
        scenaristMode = mode;

        if(mode === "Main") {
            $(".menu-main").show();
            $(".menu-settings").hide();
            $(".menu-editor").hide();
            $(".menu-simulator").hide();
            $(".menu-spline").hide();
            $(".menu-sensor").hide();
            $(".menu-event").hide();
            // $("#menu-mode").text("Settings");
        }
        if(mode === "Settings") {
            $(".menu-main").hide();
            $(".menu-settings").show();
            $(".menu-editor").hide();
            $(".menu-simulator").hide();
            $(".menu-spline").hide();
            $(".menu-sensor").hide();
            $(".menu-event").hide();
            // $("#menu-mode").text("Editor");
        }
        if(mode === "Editor") {
            $(".menu-main").hide();
            $(".menu-settings").hide();
            $(".menu-editor").show();
            $(".menu-simulator").hide();
            $(".menu-spline").hide();
            $(".menu-sensor").hide();
            $(".menu-event").hide();
            // $("#menu-mode").text("Simulation");
        }
        if(mode === "Simulation") {
            $(".menu-main").hide();
            $(".menu-settings").hide();
            $(".menu-editor").hide();
            $(".menu-simulator").show();
            $(".menu-spline").hide();
            $(".menu-sensor").hide();
            $(".menu-event").hide();
            // $("#menu-mode").text("Sensors");
        }
        if(mode === "Sensors") {
            $(".menu-main").hide();
            $(".menu-settings").hide();
            $(".menu-editor").hide();
            $(".menu-simulator").hide();
            $(".menu-spline").hide();
            $(".menu-sensor").show();
            $(".menu-event").hide();
            // $("#menu-mode").text("Events");
        } 
        if(mode === "Events") {
            $(".menu-main").hide();
            $(".menu-settings").hide();
            $(".menu-editor").hide();
            $(".menu-simulator").hide();
            $(".menu-spline").hide();
            $(".menu-sensor").hide();
            $(".menu-event").show();
            // $("#menu-mode").text("Main");
        } 
        if(mode === "Splines") {
            $(".menu-main").hide();
            $(".menu-settings").hide();
            $(".menu-editor").hide();
            $(".menu-simulator").hide();
            $(".menu-spline").show();
            $(".menu-sensor").hide();
            $(".menu-event").hide();
            // $("#menu-mode").text("Builder");
        }

        /*if(mode === "Nodes") {
            $(".menu-main").hide();
            $(".menu-settings").hide();
            $(".menu-editor").hide();
            $(".menu-spline").hide();
            $(".menu-builder").show();
            // $("#menu-mode").text("Builder");
        }
        if(mode === "Builder") {
            $(".menu-main").show();
            $(".menu-settings").hide();
            $(".menu-editor").hide();
            $(".menu-spline").hide();
            $(".menu-builder").hide();
            // $("#menu-mode").text("Main");
        } */

    }

    $(document).ready(function() {

        // Select Settings mode - by default
        selectMode("Main");

        // Enable/disable objects based on mode selection
        $(".menu-mode-item").click( function(e) {
            selectMode( $(this).attr("data-menu") );
            $(this).siblings('button').removeClass('active');
            $(this).addClass('active');
        });

        $('#cameraDepth').slider({
            formatter: function(value) {
                return '' + value;
            }
        });

        scenestatus.watch("loaded", function (id, oldval, newval) {

            if(newval == true ) {

                $('#cameraType').click(function (){
                    
                    //console.log( "TYPE:" + $('#cameraType').text() );
                    disableControls();
                    if( $('#cameraType').text() === "Perspective") {
                        mode.camera.control = ControlMode.FPS;
                        $('#cameraType').text("Orthographic");
                        camera = cameras.persp.camera;          
                        cameras.persp.camera.position.set( camera.position.x, camera.position.y, camera.position.z );
                        renderer = cameras.persp.renderer;     
                        composer = cameras.persp.composer;
                    } else {
                        mode.camera.control = ControlMode.ORTHO;
                        $('#cameraType').text("Perspective");
                        camera = cameras.ortho.camera;
                        cameras.ortho.camera.position.set( camera.position.x, camera.position.y, camera.position.z );
                        renderer = cameras.ortho.renderer;
                        composer = cameras.ortho.composer;
                    }
                    enableControls();
                });
            }
        });
    });
</script>
